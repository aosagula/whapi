{
  "name": "Whapi — Chatbot Principal",
  "nodes": [
    {
      "id": "webhook-wpp",
      "name": "Webhook WPPConnect",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "whapi-chatbot",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "extraer-datos",
      "name": "Extraer Datos del Mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 300],
      "parameters": {
        "jsCode": "// Extrae número del remitente (cliente) y destino (comercio)\n// El webhook de WPPConnect envía el payload en data.data o directamente\nconst payload = $input.item.json;\nconst data = payload.data || payload;\n\n// Número del cliente (remitente)\nconst fromRaw = data.from || data.sender?.id || '';\nconst clientePhone = fromRaw.replace('@c.us', '').replace(/^\\+/, '');\n\n// Número del comercio (destino del mensaje)\nconst toRaw = data.to || data.session || '';\nconst comercioPhone = toRaw.replace('@c.us', '').replace(/^\\+/, '');\n\n// Contenido del mensaje\nconst mensaje = data.body || data.content || data.text || '';\nconst tipoMensaje = data.type || 'chat';\n\n// Solo procesamos mensajes de texto\nif (tipoMensaje !== 'chat' && tipoMensaje !== 'text') {\n  return [{ json: { skip: true, motivo: 'Tipo de mensaje no soportado: ' + tipoMensaje } }];\n}\n\nif (!clientePhone || !comercioPhone || !mensaje.trim()) {\n  return [{ json: { skip: true, motivo: 'Datos de mensaje incompletos' } }];\n}\n\nreturn [{ json: { clientePhone, comercioPhone, mensaje, skip: false } }];"
      }
    },
    {
      "id": "check-skip",
      "name": "¿Procesar?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-skip",
              "leftValue": "={{ $json.skip }}",
              "rightValue": false,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "resolver-tenant",
      "name": "Resolver Tenant",
