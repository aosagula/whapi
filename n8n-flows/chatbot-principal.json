        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "X-N8N-Api-Key", "value": "={{ $env.WHAPI_N8N_API_KEY }}" }]
        },
        "options": {}
      }
    },
    {
      "id": "check-tenant",
      "name": "¿Tenant encontrado?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1160, 200],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-tenant",
              "leftValue": "={{ $json.business_id }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "notEmpty" }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "cargar-contexto",
      "name": "Cargar Contexto",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1400, 100],
      "parameters": {
        "method": "GET",
        "url": "={{ $env.WHAPI_BACKEND_URL }}/n8n/comercios/{{ $('Resolver Tenant').item.json.business_id }}/contexto",
        "sendQuery": true,
        "queryParameters": {
