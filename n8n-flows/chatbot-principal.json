        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "X-N8N-Api-Key", "value": "={{ $env.WHAPI_N8N_API_KEY }}" }]
        },
        "options": {}
      }
    },
    {
      "id": "check-hitl",
      "name": "¿Bot activo?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1640, 100],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-bot",
              "leftValue": "={{ $json.session_status }}",
              "rightValue": "active_bot",
