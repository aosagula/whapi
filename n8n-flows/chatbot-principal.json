        "method": "POST",
        "url": "={{ $env.WHAPI_BACKEND_URL }}/n8n/comercios/{{ $('Construir System Prompt').item.json.business_id }}/pedidos/{{ $('Construir System Prompt').item.json.order_id }}/pago",
        "sendBody": true,
        "bodyContentType": "json",
        "jsonBody": "={{ JSON.stringify({ method: $fromAI('method', 'Método de pago: mercadopago, cash o transfer'), credit_to_apply: $fromAI('credit_to_apply', 'Monto de crédito a aplicar, 0 si no usa crédito') }) }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "X-N8N-Api-Key", "value": "={{ $env.WHAPI_N8N_API_KEY }}" }]
        }
      }
    },
    {
