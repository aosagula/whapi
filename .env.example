# ====== POSTGRES ======
POSTGRES_HOST=host.docker.internal
# Nota: en Windows/Mac con Docker Desktop, host.docker.internal resuelve al host tanto
# dentro de contenedores como desde el host. Para Linux sin Docker Desktop usar 172.17.0.1.
POSTGRES_PORT=5432
POSTGRES_USER=whapi_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=whapi_db

# ====== WPPCONNECT ======
WPPCONNECT_HOST=https://wppconnect.example.com/
WPPCONNECT_PORT=443
WPPCONNECT_SECRET_KEY=changeme

# ====== N8N ======
N8N_HOST=https://n8n.example.com/
N8N_PORT=443

# ====== AUTH ======
# Generar con: openssl rand -hex 32
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ====== MERCADOPAGO ======
MERCADOPAGO_ACCESS_TOKEN=

# ====== LLM ======
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ====== FRONTEND ======
NEXT_PUBLIC_API_URL=http://localhost:8000

# ====== CORS ======
CORS_ORIGINS=http://localhost:3000
