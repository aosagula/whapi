        }
      }
    },
    {
      "id": "guardar-msg-cliente",
      "name": "Guardar Mensaje Cliente",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1880, 0],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WHAPI_BACKEND_URL }}/n8n/comercios/{{ $('Cargar Contexto').item.json.business_id }}/mensajes",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "session_id", "value": "={{ $('Cargar Contexto').item.json.session_id }}" },
            { "name": "direction", "value": "inbound" },
            { "name": "content", "value": "={{ $('Extraer Datos del Mensaje').item.json.mensaje }}" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "X-N8N-Api-Key", "value": "={{ $env.WHAPI_N8N_API_KEY }}" }]
        },
        "options": {}
      }
    },
    {
      "id": "construir-prompt",
      "name": "Construir System Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2120, 0],
      "parameters": {
        "jsCode": "const ctx = $('Cargar Contexto').item.json;\nconst cliente = ctx.customer;\nconst pedido = ctx.active_order;\nconst mensajes = ctx.recent_messages || [];\n\n// Historial de conversación para el contexto del agente\nconst historial = mensajes.map(m => `[${m.direction === 'inbound' ? 'Cliente' : 'Bot'}]: ${m.content}`).join('\\n');\n\n// Resumen del pedido en curso\nlet resumenPedido = 'Sin pedido activo.';\nif (pedido) {\n  const items = pedido.items.map(i => `  - ${i.quantity}x ${i.product_name || 'Ítem'} $${i.subtotal.toFixed(2)}`).join('\\n');\n  resumenPedido = `Pedido #${pedido.order_number} (${pedido.status}):\\n${items}\\nTotal: $${pedido.total_amount.toFixed(2)}`;\n  if (pedido.delivery_type === 'delivery' && pedido.delivery_address) {\n    resumenPedido += `\\nEntrega en: ${pedido.delivery_address}`;\n  }\n}\n\nconst systemPrompt = `Sos el asistente virtual de ${ctx.business_name}, una pizzería. Tu rol es ayudar a los clientes a hacer sus pedidos de forma amigable y eficiente.\n\nDatos del cliente:\n- Nombre: ${cliente.name || 'No registrado aún'}\n- Teléfono: ${cliente.phone}\n- Dirección guardada: ${cliente.address || 'Ninguna'}\n- Crédito disponible: $${cliente.credit_balance.toFixed(2)}\n\nEstado actual del pedido:\n${resumenPedido}\n\nHistorial reciente de la conversación:\n${historial || 'Sin mensajes previos.'}\n\nInstrucciones:\n- Si el cliente no tiene nombre, preguntáselo al inicio.\n- Usá el catálogo cuando el cliente pregunte por productos o precios. Llamá a la herramienta consultar_catalogo.\n- Para agregar o quitar ítems del pedido, usá la herramienta gestionar_pedido.\n- Para actualizar el nombre o dirección del cliente, usá actualizar_cliente con los IDs: cliente_id=${cliente.customer_id}.\n- Cuando el cliente confirme el pedido, usá gestionar_pedido para confirmarlo.\n- Si el cliente elige el método de pago, usá la herramienta procesar_pago con pedido_id=${pedido?.order_id || 'null'}.\n- Si detectás frustración, confusión repetida o pedido explícito de hablar con una persona, usá derivar_humano con session_id=${ctx.session_id}.\n- IDs de contexto — business_id: ${ctx.business_id}, session_id: ${ctx.session_id}, customer_id: ${cliente.customer_id}, order_id: ${pedido?.order_id || 'null'}\n- Nunca inventes precios: usá siempre el catálogo.\n- Respondé siempre en español, con tono cálido y servicial.`;\n\nreturn [{ json: { systemPrompt, business_id: ctx.business_id, session_id: ctx.session_id, customer_id: cliente.customer_id, order_id: pedido?.order_id || null, mensaje: $('Extraer Datos del Mensaje').item.json.mensaje } }];"
      }
    },
