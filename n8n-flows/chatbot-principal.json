      "parameters": {
        "name": "consultar_catalogo",
        "description": "Consulta el catálogo de productos y combos del comercio. Usá esta herramienta cuando el cliente pregunta por productos, precios, ingredientes o disponibilidad.",
        "workflowId": { "__rl": true, "value": "REEMPLAZAR_CON_ID_AGENTE_CATALOGO", "mode": "id" },
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {
